# Copy to .env for local non-Docker runs. Docker Compose sets these itself.
DATABASE_URL=postgresql+psycopg://survey:survey@localhost:5432/survey
# Writable directory the LocalDirectorySource ingests on boot and on refresh.
# Uploads are saved here as timestamped CSVs; the newest wins (mounted volume in Docker).
SOURCE_DIR=/data
# Bundled sample used to seed an empty SOURCE_DIR on boot and to reset to.
BUNDLED_SAMPLE=/app/us_ai_survey_unique_50.csv
# Cross-tab cells with n below this are flagged low reliability.
MIN_RELIABLE_N=30
# Optional: enables the out-of-core LLM report when set. Leave blank to disable.
LLM_API_KEY=
